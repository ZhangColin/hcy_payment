spring:
  # 本地开发数据源配置
  # 复制此文件为 application-local.yml 并填写你的本地配置
  datasource:
    url: jdbc:postgresql://localhost:5432/aieducenter
    username: your_local_username
    password: your_local_password

  # Redis 配置（本地 Docker: docker run -d --name aiedu-redis-local -p 6379:6379 redis:7-alpine）
  data:
    redis:
      host: localhost
      port: 6379

# 开发环境：显示 SQL
spring.jpa.show-sql: true
